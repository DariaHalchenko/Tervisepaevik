<?xml version="1.0" encoding="utf-8" ?>
<FlyoutPage  
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:Tervisepaevik.View"
    xmlns:pages="clr-namespace:Tervisepaevik"
    xmlns:res="clr-namespace:Tervisepaevik.Resources.Localization"
    x:Class="Tervisepaevik.Flyout_Page"
    FlyoutLayoutBehavior="Popover">

    <FlyoutPage.Flyout>
        <ContentPage Title="{x:Static res:AppResources.Menu}">
            <StackLayout>
                <Button x:Name="btnStartPage"
                    Text="{x:Static res:AppResources.StartPage}"
                    Clicked="btnNewPage_Clicked"/>

                <Button x:Name="btnNewPage"
                    Text="{x:Static res:AppResources.NewPage}"
                    Clicked="btnStartPage_Clicked"/>

                <Button x:Name="btnHommikusookFotoPage"
                    Text="{x:Static res:AppResources.Breakfast}"
                    Clicked="btnHommikusookFotoPage_Clicked"/>

                <Button x:Name="btnLounasookFotoPage"
                    Text="{x:Static res:AppResources.Lunch}"
                    Clicked="btnLounasookFotoPage_Clicked"/>

                <Button x:Name="btnOhtusookFotoPage"
                    Text="{x:Static res:AppResources.Dinner}"
                    Clicked="btnOhtusookFotoPage_Clicked"/>

                <Button x:Name="btnVahepalaFotoPage"
                    Text="{x:Static res:AppResources.Snack}"
                    Clicked="btnVahepalaFotoPage_Clicked"/>

                <Button x:Name="btnVeejalgiminePage"
                    Text="{x:Static res:AppResources.Water}"
                    Clicked="btnVeejalgiminePage_Clicked"/>

                <Button x:Name="btnTreeningudFotoPage"
                    Text="{x:Static res:AppResources.Training}"
                    Clicked="btnTreeningudFotoPage_Clicked"/>

                <Button x:Name="btnEnesetunnePage"
                    Text="{x:Static res:AppResources.Feeling}"
                    Clicked="btnEnesetunnePage_Clicked"/>

            </StackLayout>
        </ContentPage>
    </FlyoutPage.Flyout>

    <FlyoutPage.Detail>
        <NavigationPage>
            <x:Arguments>
                <pages:StartPage Title="{x:Static res:AppResources.NewPage}"/>
            </x:Arguments>
        </NavigationPage>
    </FlyoutPage.Detail>

</FlyoutPage>